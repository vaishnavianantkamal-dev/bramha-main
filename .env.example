# ============================================
# BRAHMA VALLEY - ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and update values

# ============================================
# FRONTEND CONFIGURATION
# ============================================
VITE_APP_NAME=Brahma Valley
VITE_APP_VERSION=1.0.0

# API Configuration
VITE_API_BASE_URL=http://localhost/brahmavalley-main/brahmavalley-main/backend/api
VITE_API_TIMEOUT=30000

# Environment
VITE_ENVIRONMENT=development

# Features
VITE_DISABLE_DEVTOOLS=false

# ============================================
# BACKEND CONFIGURATION (for reference)
# ============================================
# Backend runs on: http://localhost/brahmavalley-main/brahmavalley-main/backend/

# Database
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=brahmavalley_db
DB_PORT=3306

# API Settings
API_ENVIRONMENT=development
API_DEBUG=true
